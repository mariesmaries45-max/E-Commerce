{/* Additional Payment Options */}
          <div className="payment-buttons">
            {/* Razorpay Button */}
            <button onClick={handlePayment} className="checkout-btn razorpay-btn">
              💳 Pay with Razorpay
            </button>

            {/* UPI */}
            <a 
              href="https://upi.google.com/" 
              target="_blank" 
              rel="noopener noreferrer"
              className="checkout-btn gpay-btn"
            >
              💳 Pay with UPI
            </a>

            {/* GPay */}
            <a 
              href="https://pay.google.com/" 
              target="_blank" 
              rel="noopener noreferrer"
              className="checkout-btn gpay-btn"
            >
              📱 Pay with GPay
            </a>

            {/* PhonePe */}
            <a 
              href="https://www.phonepe.com/" 
              target="_blank" 
              rel="noopener noreferrer"
